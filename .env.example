# Copy this file to ".env" and fill in real values. Never commit the real .env.

# Backend (Railway in prod) — used by FastAPI, server-side only
GEMINI_API_KEY=your_gemini_key_here

# Frontend (Vercel in prod) — these are PUBLIC, safe in the browser
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Where the frontend finds the backend.
# Local: http://localhost:8000   Prod: your Railway backend URL
VITE_API_URL=http://localhost:8000
